{
  "name": "todo-app-root",
  "version": "1.0.0",
  "scripts": {
    "install:all": "npm install && npm install --prefix todo-app/server && npm install --prefix todo-app/client",
    "dev:server": "npm run dev --prefix todo-app/server",
    "dev:client": "npm run dev --prefix todo-app/client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "dependencies": {
    "axios": "^1.18.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
